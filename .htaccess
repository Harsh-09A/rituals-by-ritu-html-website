RewriteEngine On
RewriteBase /

# -------------------------------------------------
# 1. Redirect .php → clean URL (top-level pages only)
# -------------------------------------------------
RewriteCond %{THE_REQUEST} \s/([a-zA-Z0-9_-]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# -------------------------------------------------
# 2. Load .php for clean top-level pages
# /about → about.php
# (EXCLUDE blog & property)
# -------------------------------------------------
RewriteCond %{REQUEST_URI} !^/(blog|property)/ [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [L]

# -------------------------------------------------
# 3. Blog detail page
# /blog/slug
# -------------------------------------------------
RewriteRule ^blog/([^/]+)/?$ blog-details.php?slug=$1 [L,QSA]

# -------------------------------------------------
# 4. Property detail page
# /property/slug
# -------------------------------------------------
RewriteRule ^property/([^/]+)/?$ property-details.php?slug=$1 [L,QSA]

# -------------------------------------------------
# 5. Custom 404 (MUST BE LAST)
# -------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ 404.php [L]
